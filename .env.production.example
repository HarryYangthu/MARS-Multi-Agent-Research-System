# MARS production environment template.
# Copy to .env.production on the server and fill the placeholders.

# === Public URLs ===
BACKEND_URL=https://api.example.com
NEXT_PUBLIC_BACKEND_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com
MARS_CORS_ORIGINS=https://mars.example.com,https://your-vercel-preview.vercel.app

# === Service ports bound on localhost for Nginx reverse proxy ===
BACKEND_PORT=8000
FRONTEND_PORT=3000

# === Runtime admission ===
MARS_RUNTIME_MODE=production
MARS_MOCK_MODE=never
MARS_DEFAULT_PROJECT=pimc
MARS_LOG_LEVEL=INFO

# mock is not allowed in production. Pick the backend that is actually connected.
# Common choices: pim_cpu, paper_static, local_command, remote_gpu
MARS_EXECUTION_BACKEND=pim_cpu

# === LLM provider ===
# configs/agents.yaml currently uses DeepSeek for all enabled agents.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Optional: use separate keys by setting each Agent's model.api_key_env in the
# frontend config workbench or configs/agents.yaml.
COMMANDER_DEEPSEEK_API_KEY=
IDEA_DEEPSEEK_API_KEY=
EXPERIMENT_DEEPSEEK_API_KEY=
CODING_DEEPSEEK_API_KEY=
EXECUTION_DEEPSEEK_API_KEY=
WRITING_DEEPSEEK_API_KEY=
MARS_LLM_TIMEOUT_SECONDS=60

# Optional other providers.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
GEMINI_API_KEY=

# === Infrastructure ===
REDIS_URL=redis://redis:6379/0
CHROMADB_PATH=/app/knowledge/.chromadb

# === Tools and network ===
MARS_ENABLE_NETWORK_TOOLS=false
MARS_WEB_SEARCH_ALLOWLIST=
MARS_WEB_SEARCH_PROVIDER=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=

# === Context and memory budgets ===
MARS_CONTEXT_MAX_TOKENS=32000
MARS_CONTEXT_TARGET_TOKENS=24000
MARS_CONTEXT_AUTO_COMPRESS=true
MARS_CONTEXT_TOOL_RAW_EXTERNALIZE=true
MARS_CONTEXT_WORKBENCH_ENABLED=true

# === Optional observability mirror ===
MARS_LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=mars-prod
MARS_LANGSMITH_TIMEOUT_MS=1000

# === Optional local backends ===
LOCAL_VLLM_BASE_URL=
LOCAL_VLLM_API_KEY=EMPTY
POST_TRAINING_CODING_ENDPOINT=
POST_TRAINING_CODING_MODEL=mars-coding-posttrain
CUSTOM_ENDPOINT_URL=
CUSTOM_ENDPOINT_API_KEY=
