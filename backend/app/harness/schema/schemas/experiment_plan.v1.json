{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mars://schemas/experiment_plan.v1.json",
  "title": "Experiment Agent plan frontmatter",
  "type": "object",
  "required": [
    "schema",
    "project",
    "agent",
    "variables",
    "metrics",
    "ablations",
    "estimated_runs"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "experiment_plan.v1" },
    "project": { "type": "string", "minLength": 1 },
    "agent": { "const": "experiment" },
    "upstream_artifact": { "type": "string" },
    "variables": {
      "type": "object",
      "required": ["independent", "dependent"],
      "properties": {
        "independent": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "controlled": { "type": "array", "items": { "type": "string" } },
        "dependent": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "secondary": { "type": "array", "items": { "type": "string" } }
      }
    },
    "baseline_ref": {
      "type": "object",
      "properties": {
        "matched_run_id": { "type": ["string", "null"] },
        "match_score": { "type": ["number", "null"] },
        "reuse_decision": { "enum": ["rerun", "reuse", "modify", null] }
      }
    },
    "ablations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "config"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "config": { "type": "object" }
        }
      }
    },
    "estimated_runs": { "type": "integer", "minimum": 1 },
    "estimated_gpu_hours": { "type": "number", "minimum": 0 }
  }
}
