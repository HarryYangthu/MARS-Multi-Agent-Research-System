{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mars://schemas/proposal.v1.json",
  "title": "Idea Agent proposal frontmatter",
  "type": "object",
  "required": [
    "schema",
    "project",
    "agent",
    "research_question",
    "hypothesis",
    "novelty"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "proposal.v1" },
    "project": { "type": "string", "minLength": 1 },
    "agent": { "const": "idea" },
    "created": { "type": "string" },
    "research_question": { "type": "string", "minLength": 8 },
    "hypothesis": { "type": "string", "minLength": 8 },
    "novelty": { "type": "string", "minLength": 8 },
    "theoretical_basis": { "type": "string" },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_literature": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "testable_predictions": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["prediction"],
            "additionalProperties": true,
            "properties": {
              "prediction": { "type": "string", "minLength": 1 },
              "metric": { "type": "string" },
              "expected_direction": { "type": "string" },
              "success_threshold": { "type": "string" }
            }
          }
        ]
      }
    },
    "experiment_hint": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "variables": { "type": "array", "items": { "type": "string" } },
            "metrics": { "type": "array", "items": { "type": "string" } },
            "minimal_ablations": {
              "type": "array",
              "items": {
                "anyOf": [
                  { "type": "string" },
                  { "type": "object", "additionalProperties": true }
                ]
              }
            }
          }
        }
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["ref"],
            "additionalProperties": true,
            "properties": {
              "ref": { "type": "string", "minLength": 1 },
              "kind": { "type": "string" },
              "summary": { "type": "string" }
            }
          }
        ]
      }
    },
    "risk_register": {
      "type": "array",
      "items": {
        "anyOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["risk"],
            "additionalProperties": true,
            "properties": {
              "risk": { "type": "string", "minLength": 1 },
              "severity": { "enum": ["low", "medium", "high"] },
              "mitigation": { "type": "string" }
            }
          }
        ]
      }
    },
    "downstream_requirements": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "research_artifacts": {
      "type": "object",
      "additionalProperties": true
    },
    "quality_warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "debate_summary": {
      "type": "object",
      "properties": {
        "rounds": { "type": "integer", "minimum": 0 },
        "consensus": { "type": "string" },
        "disagreements": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "evidence_gaps": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
