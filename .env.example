# MARS V0 — environment variables
# All LLM keys are OPTIONAL. Missing keys auto-fallback to mock_provider.

# === LLM API Keys ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
GEMINI_API_KEY=

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Local backends ===
LOCAL_VLLM_BASE_URL=http://localhost:8001/v1
LOCAL_VLLM_API_KEY=EMPTY

CUSTOM_ENDPOINT_URL=
CUSTOM_ENDPOINT_API_KEY=

# === Infrastructure ===
REDIS_URL=redis://localhost:6379/0
CHROMADB_PATH=./knowledge/.chromadb

# === Service ports ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# === Mode flags ===
# auto | always | never
MARS_MOCK_MODE=auto
MARS_LOG_LEVEL=INFO
# Agent natural-language output: zh | en (schema keys/enums stay English)
MARS_AGENT_LANGUAGE=zh

# === Project default ===
MARS_DEFAULT_PROJECT=moe-pimc
