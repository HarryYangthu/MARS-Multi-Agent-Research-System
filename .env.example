# MARS V0 — environment variables
# All LLM keys are OPTIONAL. Missing keys auto-fallback to mock_provider.

# === LLM API Keys ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
GEMINI_API_KEY=

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Local backends ===
LOCAL_VLLM_BASE_URL=http://localhost:8001/v1
LOCAL_VLLM_API_KEY=EMPTY

# Coding Agent post-training endpoint (V0 load-only).
# Keep secrets out of configs/agents.yaml; reference this env var via api_key_env.
POST_TRAINING_CODING_ENDPOINT=http://127.0.0.1:8001/v1
POST_TRAINING_CODING_MODEL=mars-coding-posttrain

CUSTOM_ENDPOINT_URL=
CUSTOM_ENDPOINT_API_KEY=

# === Infrastructure ===
REDIS_URL=redis://localhost:6379/0
CHROMADB_PATH=./knowledge/.chromadb

# === Service ports ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# === Mode flags ===
# development | staging | production
MARS_RUNTIME_MODE=development
# auto | always | never
MARS_MOCK_MODE=auto
# mock | pim_cpu | local_command | docker_command | remote_gpu
MARS_EXECUTION_BACKEND=mock
MARS_LOG_LEVEL=INFO
# Seconds before a real LLM call times out. Development falls back to mock;
# production should set this high enough for the selected provider/model.
MARS_LLM_TIMEOUT_SECONDS=15
# Network-backed tools (arXiv/web) are implemented but off by default so the
# zero-dependency demo stays offline-safe.
MARS_ENABLE_NETWORK_TOOLS=false
MARS_WEB_SEARCH_ALLOWLIST=
# empty | brave | tavily | serper
MARS_WEB_SEARCH_PROVIDER=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=

# Optional MCP adapter health toggles. Agents still call MARS tool names.
MARS_MCP_CHROMA_ENABLED=false
MARS_MCP_CHROMA_COMMAND=
MARS_MCP_FILESYSTEM_COMMAND=
MARS_MCP_FILESYSTEM_ROOTS=
MARS_MCP_GIT_COMMAND=
MARS_MCP_GITHUB_ENABLED=false
MARS_MCP_GITHUB_COMMAND=

# === Context Engineering V1 ===
MARS_CONTEXT_MAX_TOKENS=32000
MARS_CONTEXT_TARGET_TOKENS=24000
MARS_CONTEXT_AUTO_COMPRESS=true
MARS_CONTEXT_TOOL_RAW_EXTERNALIZE=true
MARS_CONTEXT_WORKBENCH_ENABLED=true

# === Optional observability mirrors ===
# File-backed traces under runs/<id>/context stay mandatory. LangSmith is an
# external mirror only and is disabled by default.
MARS_LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=mars-dev
MARS_LANGSMITH_TIMEOUT_MS=1000

# === Project default ===
MARS_DEFAULT_PROJECT=moe-pimc
